  },
  "devDependencies": {
    "@ant-design/icons": "^6.2.5",
    "@rc-component/father-plugin": "^2.2.0",
    "@rc-component/np": "^1.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.1",
    "@types/raf": "^3.4.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/warning": "^3.0.4",
    "antd": "^6.3.4",
