    "husky": "^9.1.7",
    "less": "^4.6.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.0",
    "rc-test": "^7.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stylelint": "^17.1.0",
    "stylelint-config-standard-less": "^4.0.0",
    "typescript": "^5.9.3"
