{
  "name": "@rc-component/drawer",
  "version": "1.4.2",
  "description": "drawer component for react",
  "keywords": [
    "react",
    "react-component",
    "react-drawer",
    "drawer",
    "drawer-menu",
    "rc-drawer-menu",
    "react-drawer-menu",
    "animation",
    "drawer-motion",
    "drawer-animation"
  ],
  "homepage": "https://react-component.github.io/drawer",
